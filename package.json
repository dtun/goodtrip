{
  "name": "goodtrip-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "GOODTrip — collaborative, AI-assisted travel itinerary app. Monorepo.",
  "scripts": {
    "web": "pnpm --filter goodtrip-web",
    "mobile": "pnpm --filter goodtrip-mobile",
    "dev:web": "pnpm --filter goodtrip-web dev",
    "build:web": "pnpm --filter goodtrip-web build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@8.15.0",
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
