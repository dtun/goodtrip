# Supabase project (spec section 13). For local dev, `supabase start` prints
# the URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The single hardcoded trip for the DC 2026 beta — the seeded trip id from
# supabase/seed.sql.
NEXT_PUBLIC_GOODTRIP_TRIP_ID=11111111-1111-4111-8111-111111111111
